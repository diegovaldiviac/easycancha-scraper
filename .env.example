# ── .env — configuración compartida entre todas las reservas ──────────────

# Credenciales de tu cuenta easycancha
EMAIL=tucorreo@ejemplo.com
PASSWORD=TuContrasena123

# Configuración del scheduling (aplica a todas las reservas)
BOOKING_ADVANCE_DAYS=7  # Cuántos días antes abre la cancha las reservas (por defecto 7)
BOOKING_RELEASE_HOUR=00:00  # A qué hora (24h) se liberan los turnos (por defecto medianoche)
TZ=America/Santiago  # Timezone del servidor — crítico para que el scheduler use hora chilena

# IP pública del servidor de deploy (Oracle Cloud u otro VPS)
SERVER_IP=0.0.0.0

# Proxy residencial (opcional — recomendado en despliegues cloud para evitar bloqueos por IP)
# Formato del servidor: http://<host>:<puerto>
PROXY_SERVER=http://proxy.ejemplo.io:9000
PROXY_USERNAME=usuario_proxy
PROXY_PASSWORD=contrasena_proxy

# ── .env.bookingN — una reserva por archivo, ver .env.booking1.example ────
