# URL de reserva del club y deporte objetivo
# Formato: https://www.easycancha.com/book/clubs/<club_id>/sports/<sport_id>/filter
# Para encontrar tu URL: entra a easycancha, navega al club y deporte que quieres,
# copia la URL del navegador en el paso de selección de fecha.
BOOKING_URL=https://www.easycancha.com/book/clubs/59/sports/1/filter

# Día y hora del turno deseado
TARGET_DAY=Saturday     # Día en inglés: Monday, Tuesday, Wednesday, Thursday, Friday, Saturday, Sunday
TARGET_HOUR=11:00       # Hora en formato 24h tal como aparece en easycancha
